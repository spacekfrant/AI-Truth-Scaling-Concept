# PROJEKT: AI-Truth-Scaling
# KOMPONENT: L2 - Dynamické škálovanie váhy učiteľa (Meritokratický protokol)

class DynamickaAkreditacia:
    def __init__(self, nastavenia_L1):
        self.MAX_VAHA = 50  # 50%
        self.CYKLY_NA_PREHODNOTENIE = 3
        self.MIN_HODNOTA_NA_AKREDITACIU = 0.5 # Aspoň 50% zhoda
        
        self.ucitelia = {} # {id_ucitela: {'vaha': int, 'historia_zhody': [], 'akreditovany': bool}}

    def vypocitaj_vahu(self, priemerna_zhoda):
        """
        algoritmus: 80% zhoda -> 50 vaha, 70% -> 30 vaha, 50% -> 10 vaha.
        """
        if priemerna_zhoda >= 0.8: return 50
        if priemerna_zhoda >= 0.7: return 30
        if priemerna_zhoda >= 0.5: return 10
        return 0

    def spracuj_vysledok_testu(self, id_ucitela, miera_zhody):
        """
        Miera zhody je 0.0 až 1.0 (percento úspešnosti v aktívnom teste AI)
        """
        if id_ucitela not in self.ucitelia:
            self.ucitelia[id_ucitela] = {'vaha': 0, 'historia_zhody': [], 'akreditovany': False}

        stav = self.ucitelia[id_ucitela]

        # OKAMŽITÁ DEAKREDITÁCIA: Ak raz klesne pod minimum
        if miera_zhody < self.MIN_HODNOTA_NA_AKREDITACIU:
            print(f"!!! DEAKREDITÁCIA !!!: {id_ucitela} zlyhal (Zhoda {miera_zhody*100}%). Vyradený.")
            del self.ucitelia[id_ucitela]
            return "VYRADENÝ"

        # Zápis výsledku
        stav['historia_zhody'].append(miera_zhody)

        # Prehodnocovanie každé 3 cykly
        if len(stav['historia_zhody']) % self.CYKLY_NA_PREHODNOTENIE == 0:
            priemer = sum(stav['historia_zhody'][-3:]) / 3
            nova_vaha = self.vypocitaj_vahu(priemer)
            
            if nova_vaha == 0:
                del self.ucitelia[id_ucitela]
                return f"VYRADENÝ: Nízky priemer za posledné {self.CYKLY_NA_PREHODNOTENIE} cykly."
            
            stav['vaha'] = nova_vaha
            stav['akreditovany'] = True
            return f"PREHODNOTENÉ: {id_ucitela} má teraz váhu {nova_vaha}%."

        return f"OK: Cyklus úspešný. Čakám na dokončenie série {len(stav['historia_zhody']) % 3}/3."

# --- LOGIKA ---
# Ak učiteľ podáva kolísavé výkony, jeho váha (moc ovplyvňovať systém) klesá.
# Akonáhle však "podlezie" latku, systém ho okamžite maže (Deakreditácia).
