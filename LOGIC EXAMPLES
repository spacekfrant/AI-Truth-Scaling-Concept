# PROJECT: AI-Truth-Scaling
# COMPONENT: L2 - Dynamic Teacher Weight Scaling (Meritocratic Protocol)

class DynamicAccreditation:
    def __init__(self, L1_config):
        self.MAX_WEIGHT = 50 
        self.RE_EVAL_CYCLES = 3
        self.MIN_THRESHOLD = 0.5 # Min 50% match
        self.teachers = {} # {id: {'weight': int, 'history': [], 'is_accredited': bool}}

    def calculate_weight(self, avg_consensus):
        if avg_consensus >= 0.8: return 50
        if avg_consensus >= 0.7: return 30
        if avg_consensus >= 0.5: return 10
        return 0

    def process_test_result(self, teacher_id, match_score):
        if teacher_id not in self.teachers:
            self.teachers[teacher_id] = {'weight': 0, 'history': [], 'is_accredited': False}

        status = self.teachers[teacher_id]

        # INSTANT DE-ACCREDITATION: If performance drops below minimum even once
        if match_score < self.MIN_THRESHOLD:
            print(f"!!! DE-ACCREDITATION !!!: {teacher_id} failed (Match {match_score*100}%). Removed.")
            del self.teachers[teacher_id]
            return "REMOVED"

        status['history'].append(match_score)

        # Re-evaluate weight every 3 cycles
        if len(status['history']) % self.RE_EVAL_CYCLES == 0:
            avg = sum(status['history'][-3:]) / 3
            new_weight = self.calculate_weight(avg)
            
            if new_weight == 0:
                del self.teachers[teacher_id]
                return "REMOVED: Low average over the last 3 cycles."
            
            status['weight'] = new_weight
            status['is_accredited'] = True
            return f"RE-EVALUATED: {teacher_id} now has a weight of {new_weight}%."

        return f"OK: Cycle successful. Waiting for series {len(status['history']) % 3}/3."

