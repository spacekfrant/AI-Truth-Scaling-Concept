# KOMPONENT: L2/L3 - Dynamické škálovanie a Reporting odchýlok pre L1/L0

class SystemPravdy:
    def __init__(self, nastavenia_L1):
        self.tolerancia_L1 = nastavenia_L1['max_odchylka'] # Definované Konzorciom
        self.pamat_pravdy = {
            "INFO_777": {"obsah": "Zákon zachovania energie", "ip": 1.0, "n": 100}
        }
        # List prístupný pre L0 a L1 na dopyt
        self.list_podozrivych_odchylok = []

    def precalculate_and_report(self, id_info, respondent_id, odpoved_val, vaha_respondenta):
        info = self.pamat_pravdy[id_info]
        stary_ip = info['ip']

        # 1. VÝPOČET ODCHÝLKY
        aktualna_odchylka = abs(stary_ip - odpoved_val)

        # 2. AK JE ODCHÝLKA NAD NORMU, ZÁPIS DO LISTU PRE L1/L0
        if aktualna_odchylka > self.tolerancia_L1:
            zaznam = {
                "info_id": id_info,
                "respondent": respondent_id,
                "povodny_ip": stary_ip,
                "odpoved_respondenta": odpoved_val,
                "odchylka": aktualna_odchylka,
                "vaha_vplyvu": vaha_respondenta
            }
            self.list_podozrivych_odchylok.append(zaznam)
            print(f"!!! VÝSTRAHA: Odchýlka {aktualna_odchylka} nahlásená do listu pre L1/L0.")

        # 3. SAMOTNÉ ŠKÁLOVANIE (Vážený priemer)
        # Nový IP = (Starý IP * Počet overení + Nová odpoveď * Váha) / (Počet + Váha)
        novy_ip = (stary_ip * info['n'] + odpoved_val * vaha_respondenta) / (info['n'] + vaha_respondenta)
        
        info['ip'] = round(novy_ip, 6)
        info['n'] += vaha_respondenta
        
        return info['ip']

    def dopyt_pre_L1(self):
        """Funkcia pre L1/L0 na zobrazenie problémových odpovedí."""
        return self.list_podozrivych_odchylok

